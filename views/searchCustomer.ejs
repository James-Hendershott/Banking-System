<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Customer</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/bootstrap-icons.css">
</head>
<body>
    <!-- Include Navbar -->
    <%- include('partials/navbar') %>

    <div class="container mt-5">
        <h2 class="text-center text-primary">Search Customer</h2>
        
        <!-- Search Form -->
        <form action="/employee/manage-customer" method="POST" class="mt-4">
            <div class="input-group">
                <input type="text" name="username" class="form-control" placeholder="Enter Customer Username" required>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
        </form>

        <!-- Error Display -->
        <% if (error) { %>
            <div class="alert alert-danger text-center mt-3">
                <%= error %>
            </div>
        <% } %>

        <div class="mt-3">
            <a href="/employee/account" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Employee Account
            </a>
        </div>
    </div>
</body>
</html>
