<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Search Customer</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/bootstrap-icons.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container mt-5">
        <h2 class="text-center">Search Customer</h2>
        
        <!-- Search Form -->
        <form action="/employee/search" method="GET" class="mt-4">
            <div class="mb-3">
                <label for="searchParam" class="form-label">Search By</label>
                <select name="search_type" id="searchParam" class="form-select" required>
                    <option value="" disabled selected>Select Search Type</option>
                    <option value="username">Username</option>
                    <option value="user_id">User ID</option>
                </select>
            </div>
            <div class="mb-3">
                <label for="searchValue" class="form-label">Search Value</label>
                <input type="text" id="searchValue" name="search_value" class="form-control" required placeholder="Enter username or user ID">
            </div>
            <button type="submit" class="btn btn-primary">Search</button>
        </form>

        <!-- Back to Dashboard -->
        <div class="text-center mt-4">
            <a href="/employee/account" class="btn btn-secondary">Back to Dashboard</a>
        </div>
    </div>
</body>
</html>
