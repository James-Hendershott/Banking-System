<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registration Successful</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
    <script>
      // Automatic redirect to login page after 15 seconds with autofilled username
      setTimeout(() => {
        window.location.href = "/login?username=<%= uniqueID %>";
      }, 15000);
    </script>
  </head>
  <body>
    <div class="container mt-5">
      <h2 class="text-center text-success">Registration Successful!</h2>
      <p class="text-center">
        Thank you, <%= firstName %>! Your unique ID (username) is:
      </p>
      <h3 class="text-center text-primary"><strong><%= uniqueID %></strong></h3>
      <p class="text-center mt-4">
        Use this username to log in. Please keep it safe and remember it.
        A confirmation message has been sent to your provided email address.
      </p>
      <div class="text-center mt-4">
        <a href="/login?username=<%= uniqueID %>" class="btn btn-primary">Go to Login</a>
      </div>
    </div>
  </body>
</html>
