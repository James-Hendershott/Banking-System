<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Customer Account</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
  </head>
  <body>
    <!-- Include Navbar -->
    <%- include('partials/navbar') %>

    <!-- Main Container -->
    <div class="container mt-5">
      <h2 class="text-center text-primary">My Accounts</h2>

      <!-- Account Balances -->
      <div class="card mt-4">
        <div class="card-body">
          <h5>
            <a href="/customer/account/checking" class="text-decoration-none">
              Checking Account Balance: $<%= customerData.checkingBalance %>
            </a>
          </h5>
          <h5>
            <a href="/customer/account/savings" class="text-decoration-none">
              Savings Account Balance: $<%= customerData.savingsBalance %>
            </a>
          </h5>
        </div>
      </div>

      <!-- Transaction History -->
      <h4 class="mt-5">Transaction History</h4>
      <ul class="list-group">
        <% customerData.recentTransactions.forEach(transaction => { %>
        <li class="list-group-item">
          <%= transaction.date %> - <%= transaction.type %> - $<%= transaction.amount %>
        </li>
        <% }) %>
      </ul>

      <!-- Transfer Funds Button -->
      <a href="/transfer" class="btn btn-primary w-100">
        <i class="bi bi-arrow-left-right"></i> Transfer Funds
      </a>

      <!-- Deposit Form -->
      <h4 class="mt-5">Deposit Funds</h4>
      <form action="/customer/deposit" method="POST" class="mt-3">
          <div class="mb-3">
              <label for="depositAccount" class="form-label">Account</label>
              <select name="account_id" id="depositAccount" class="form-select" required>
                <% customerData.accounts.forEach(account => { %>
                  <option value="<%= account.account_id %>">
                    <%= account.account_type %> ($<%= account.balance %>)
                  </option>
                <% }); %>
              </select>

          </div>
          <div class="mb-3">
              <label for="depositAmount" class="form-label">Amount</label>
              <input
                  type="number"
                  name="amount"
                  id="depositAmount"
                  class="form-control"
                  min="0.01"
                  step="0.01"
                  required
              />
          </div>
          <div class="mb-3">
              <label for="depositType" class="form-label">Deposit Type</label>
              <select name="deposit_type" id="depositType" class="form-select">
                  <option value="cash">Cash</option>
                  <option value="check">Check</option>
                  <option value="credit_card">Credit Card</option>
              </select>
          </div>
          <div class="mb-3">
              <label for="validation" class="form-label">Validation (Optional)</label>
              <input type="text" name="validation" id="validation" class="form-control" />
          </div>
          <button type="submit" class="btn btn-success w-100">
              <i class="bi bi-plus-circle"></i> Deposit Funds
          </button>
      </form>


      <!-- Withdraw Form -->
      <h4 class="mt-5">Withdraw Funds</h4>
      <form action="/customer/withdraw" method="POST" class="mt-3">
          <div class="mb-3">
              <label for="withdrawAccount" class="form-label">Account</label>
              <select name="account_id" id="withdrawAccount" class="form-select" required>
                <% customerData.accounts.forEach(account => { %>
                  <option value="<%= account.account_id %>"><%= account.account_type %> ($<%= account.balance %>)</option>
                <% }); %>
              </select>

          </div>
          <div class="mb-3">
              <label for="withdrawAmount" class="form-label">Amount</label>
              <input
                  type="number"
                  name="amount"
                  id="withdrawAmount"
                  class="form-control"
                  min="0.01"
                  step="0.01"
                  required
              />
          </div>
          <button type="submit" class="btn btn-danger w-100">
              <i class="bi bi-dash-circle"></i> Withdraw Funds
          </button>
      </form>


      <!-- Change Password Form -->
      <h4 class="mt-5">Change Password</h4>
      <form action="/customer/change-password" method="POST">
        <div class="mb-3">
            <label for="currentPassword" class="form-label">Current Password</label>
            <input type="password" name="currentPassword" id="currentPassword" class="form-control" required />
        </div>
        <div class="mb-3">
            <label for="newPassword" class="form-label">New Password</label>
            <input type="password" name="newPassword" id="newPassword" class="form-control" required />
        </div>
        <button type="submit" class="btn btn-primary">Change Password</button>
    </form>   

    </div>
  </body>
</html>
