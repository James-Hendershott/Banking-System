<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Customer Account</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
  </head>
  <body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <a class="navbar-brand" href="/">Banking System</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Customer Account Details -->
    <div class="container mt-5">
  <h2 class="text-center text-primary">My Accounts</h2>
  <div class="card mt-4">
    <div class="card-body">
      <!-- Link to Checking Account Transactions -->
      <h5>
        <a href="/customer/account/checking" class="text-decoration-none">
          Checking Account Balance: $<%= customerData.checkingBalance %>
        </a>
      </h5>
      
      <!-- Link to Savings Account Transactions -->
      <h5>
        <a href="/customer/account/savings" class="text-decoration-none">
          Savings Account Balance: $<%= customerData.savingsBalance %>
        </a>
      </h5>
    </div>
  </div>
</div>


      <!-- Transaction History -->
      <h4 class="mt-5">Transaction History</h4>
      <ul class="list-group">
         <% customerData.recentTransactions.forEach(transaction => { %>
            <li class="list-group-item">
               <%= transaction.date %> - <%= transaction.type %> - $<%= transaction.amount %>
            </li>
         <% }) %>
      </ul>


      <!-- Transfer Funds Button -->
      <form action="/transfer" method="POST" class="mt-4">
        <button type="submit" class="btn btn-primary w-100">
          <i class="bi bi-arrow-left-right"></i> Transfer Funds
        </button>
      </form>
      

      <!-- Change Password Form -->
      <h4 class="mt-5">Change Password</h4>
      <form action="/customer/change-password" method="POST" class="mt-3">
        <div class="mb-3">
          <label for="currentPassword" class="form-label"
            >Current Password</label
          >
          <input
            type="password"
            name="currentPassword"
            id="currentPassword"
            class="form-control"
            required
          />
        </div>
        <div class="mb-3">
          <label for="newPassword" class="form-label">New Password</label>
          <input
            type="password"
            name="newPassword"
            id="newPassword"
            class="form-control"
            required
          />
        </div>
        <button type="submit" class="btn btn-warning w-100">
          <i class="bi bi-key-fill"></i> Change Password
        </button>
      </form>
    </div>
  </body>
</html> 