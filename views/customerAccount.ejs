<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Customer Account</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
  </head>
  <body>
    <!-- Include Navbar -->
    <%- include('partials/navbar') %>

    <div class="container mt-5">
      <h2 class="text-center text-primary">My Accounts</h2>

      <!-- Account Balances -->
      <div class="card mt-4">
        <div class="card-body">
          <% accounts.forEach(account => { %>
            <% if (account && account.account_type) { %> <!-- Safeguard -->
              <h5>
                <a href="/customer/account/<%= account.account_type.toLowerCase() %>" class="text-decoration-none">
                  <%= account.account_type %> Account Balance: $<%= (account.balance || 0).toFixed(2) %>
                </a>
              </h5>
            <% } else { %>
              <p class="text-danger">Account information is missing or invalid.</p>
            <% } %>
          <% }); %>
        </div>
      </div>

      <!-- Recent Transactions -->
      <h4 class="mt-5">Recent Transactions</h4>
      <ul class="list-group">
        <% if (transactions && transactions.length > 0) { %>
          <% transactions.forEach(transaction => { %>
            <li class="list-group-item">
              <strong><%= transaction.accountType || 'Unknown Account' %>:</strong>
              <% if (transaction.transactions && transaction.transactions.length > 0) { %>
                <% transaction.transactions.forEach(txn => { %>
                  <p>
                    <%= txn.timestamp || 'Unknown Date' %> - $<%= txn.amount || 0 %> - <%= txn.memo || 'No Memo' %>
                  </p>
                <% }); %>
              <% } else { %>
                <p>No transactions available for this account.</p>
              <% } %>
            </li>
          <% }); %>
        <% } else { %>
          <li class="list-group-item">No recent transactions available.</li>
        <% } %>
      </ul>
      
      <!-- Additional Forms: Deposit, Withdraw, and Change Password -->
      <h4 class="mt-5">Manage Your Accounts</h4>
      <form action="/customer/deposit" method="POST" class="mt-3">
        <!-- Deposit Form -->
        <div class="mb-3">
          <label for="depositAccount" class="form-label">Deposit Account</label>
          <select name="account_id" id="depositAccount" class="form-select" required>
            <option value="" disabled selected>Select an account</option>
            <% accounts.forEach(account => { %>
              <% if (account && account.account_id) { %>
                <option value="<%= account.account_id %>"><%= account.account_type || 'Unknown' %> ($<%= account.balance || 0 %>)</option>
              <% } %>
            <% }); %>
          </select>
        </div>
        <div class="mb-3">
          <label for="depositAmount" class="form-label">Amount</label>
          <input type="number" name="amount" id="depositAmount" class="form-control" min="0.01" step="0.01" required />
        </div>
        <button type="submit" class="btn btn-success w-100">Deposit Funds</button>
      </form>
    </div>
  </body>
</html>
