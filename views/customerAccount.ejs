<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Customer Account</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
  </head>
  <body>
    <!-- Include Navbar -->
    <%- include('partials/navbar') %>

    <div class="container mt-5">
      <h2 class="text-center text-primary">My Accounts</h2>

      <!-- Account Balances -->
      <div class="card mt-4">
        <div class="card-body">
          <% if (accounts.length > 0) { %>
            <% accounts.forEach(account => { %>
              <% if (account && account.account_type) { %>
                <h5>
                  <a href="/customer/account/<%= account.account_type.toLowerCase() %>" class="text-decoration-none">
                    <%= account.account_type %> Account Balance: $<%= (account.balance || 0).toFixed(2) %>
                  </a>
                </h5>
              <% } else { %>
                <p class="text-danger">Account information is missing or invalid.</p>
              <% } %>
            <% }); %>
          <% } else { %>
            <p class="text-danger">No accounts found.</p>
          <% } %>
        </div>
      </div>

      <!-- Recent Transactions -->
      <h4 class="mt-5">Recent Transactions</h4>
      <ul class="list-group">
        <% if (transactions.length > 0) { %>
          <% transactions.forEach(transaction => { %>
            <% if (transaction.transactions.length > 0) { %>
              <li class="list-group-item">
                <strong><%= transaction.accountType || 'Unknown Account' %>:</strong>
                <% transaction.transactions.forEach(txn => { %>
                  <p>
                    <%= txn.timestamp || 'Unknown Date' %> - $<%= txn.amount || 0 %> - <%= txn.memo || 'No Memo' %>
                  </p>
                <% }); %>
              </li>
            <% } else { %>
              <li class="list-group-item">
                <p>No transactions available for this account.</p>
              </li>
            <% } %>
          <% }); %>
        <% } else { %>
          <li class="list-group-item">No recent transactions available.</li>
        <% } %>
      </ul>

      <!-- Additional Forms: Deposit, Withdraw, Transfer, and Change Password -->
      <h4 class="mt-5">Manage Your Accounts</h4>

      <!-- Deposit Form -->
      <form action="/customer/deposit" method="POST" class="mt-3">
        <div class="mb-3">
          <label for="depositAccount" class="form-label">Deposit Account</label>
          <select name="account_id" id="depositAccount" class="form-select" required>
            <option value="" disabled selected>Select an account</option>
            <% accounts.forEach(account => { %>
              <option value="<%= account.account_id %>"><%= account.account_type %> ($<%= account.balance %>)</option>
            <% }); %>
          </select>
        </div>
        <div class="mb-3">
          <label for="depositAmount" class="form-label">Amount</label>
          <input type="number" name="amount" id="depositAmount" class="form-control" min="0.01" step="0.01" required />
        </div>
        <button type="submit" class="btn btn-success w-100">Deposit Funds</button>
      </form>

      <!-- Withdraw Form -->
      <form action="/customer/withdraw" method="POST" class="mt-3">
        <div class="mb-3">
          <label for="withdrawAccount" class="form-label">Withdraw Account</label>
          <select name="account_id" id="withdrawAccount" class="form-select" required>
            <option value="" disabled selected>Select an account</option>
            <% accounts.forEach(account => { %>
              <option value="<%= account.account_id %>"><%= account.account_type %> ($<%= account.balance %>)</option>
            <% }); %>
          </select>
        </div>
        <div class="mb-3">
          <label for="withdrawAmount" class="form-label">Amount</label>
          <input type="number" name="amount" id="withdrawAmount" class="form-control" min="0.01" step="0.01" required />
        </div>
        <button type="submit" class="btn btn-danger w-100">Withdraw Funds</button>
      </form>

      <!-- Transfer Form -->
      <form action="/customer/transfer" method="POST" class="mt-3">
        <div class="mb-3">
          <label for="fromAccount" class="form-label">From Account</label>
          <select name="from_account_id" id="fromAccount" class="form-select" required>
            <option value="" disabled selected>Select an account</option>
            <% accounts.forEach(account => { %>
              <option value="<%= account.account_id %>"><%= account.account_type %> ($<%= account.balance %>)</option>
            <% }); %>
          </select>
        </div>
        <div class="mb-3">
          <label for="toAccount" class="form-label">To Account</label>
          <select name="to_account_id" id="toAccount" class="form-select" required>
            <option value="" disabled selected>Select an account</option>
            <% accounts.forEach(account => { %>
              <option value="<%= account.account_id %>"><%= account.account_type %> ($<%= account.balance %>)</option>
            <% }); %>
          </select>
        </div>
        <div class="mb-3">
          <label for="transferAmount" class="form-label">Amount</label>
          <input type="number" name="amount" id="transferAmount" class="form-control" min="0.01" step="0.01" required />
        </div>
        <div class="mb-3">
          <label for="memo" class="form-label">Memo</label>
          <input type="text" name="memo" id="memo" class="form-control" placeholder="Optional" />
        </div>
        <button type="submit" class="btn btn-primary w-100">Transfer Funds</button>
      </form>

      <!-- Change Password Form -->
      <form action="/customer/change-password" method="POST" class="mt-3">
        <div class="mb-3">
          <label for="currentPassword" class="form-label">Current Password</label>
          <input type="password" name="currentPassword" id="currentPassword" class="form-control" required />
        </div>
        <div class="mb-3">
          <label for="newPassword" class="form-label">New Password</label>
          <input type="password" name="newPassword" id="newPassword" class="form-control" required />
        </div>
        <button type="submit" class="btn btn-primary w-100">Change Password</button>
      </form>
    </div>
  </body>
</html>
