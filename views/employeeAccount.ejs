<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Employee Account</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
</head>
<body>
    <!-- Include Navbar -->
    <%- include('partials/navbar') %>

    <div class="container mt-5">
        <h2 class="text-center text-primary">Employee Account</h2>

        <div class="row mt-5">
            <!-- Manage Own Account -->
            <div class="col-md-6">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title">Manage My Own Account</h5>
                        <p class="card-text">View your account details, transactions, and manage your funds.</p>
                        <a href="/employee/own-account" class="btn btn-primary">
                            <i class="bi bi-person-circle"></i> My Account
                        </a>
                    </div>
                </div>
            </div>

            <!-- Manage Customer Account -->
            <div class="col-md-6">
                <div class="card text-center">
                    <div class="card-body">
                        <h5 class="card-title">Manage Customer Account</h5>
                        <p class="card-text">Search for customer accounts and manage their finances.</p>
                        <a href="/employee/manage-customer" class="btn btn-secondary">
                            <i class="bi bi-people-fill"></i> Customer Management
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
