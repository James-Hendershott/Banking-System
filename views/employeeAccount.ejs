<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Employee Account</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
  </head>
  <body>
    <!-- Navbar -->
    <% include partials/navbar %>

    <!-- Employee's Own Account Details -->
    <div class="container mt-5">
      <h2 class="text-center text-primary">My Employee Account</h2>
      <div class="card mt-4">
        <div class="card-body">
          <!-- Link to Checking Account Transactions -->
          <h5>
            <a href="/employee/account/checking" class="text-decoration-none">
              Checking Account Balance: $<%= employeeData.checkingBalance %>
            </a>
          </h5>

          <!-- Link to Savings Account Transactions -->
          <h5>
            <a href="/employee/account/savings" class="text-decoration-none">
              Savings Account Balance: $<%= employeeData.savingsBalance %>
            </a>
          </h5>
        </div>
      </div>
    </div>

    <!-- Employee Transaction History Overview -->
    <h4 class="mt-5">Transaction History</h4>
    <ul class="list-group">
      <% employeeData.recentTransactions.forEach(transaction => { %>
      <li class="list-group-item">
        <%= transaction.date %> - <%= transaction.type %> - $<%=
        transaction.amount %>
      </li>
      <% }) %>
    </ul>

    <!-- Access Customer Accounts Form -->
    <div class="container mt-4">
      <h4>Search Customer Account</h4>
      <form action="/employee/manage-customer" method="POST" class="mt-4">
        <div class="input-group">
          <input
            type="text"
            name="customerId"
            class="form-control"
            placeholder="Enter Customer ID"
            required
          />
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i> View Customer Account
          </button>
        </div>
      </form>
    </div>
  </body>
</html>
