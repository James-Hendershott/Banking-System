<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Transfer Funds</title>
    <link rel="stylesheet" href="css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
  </head>
  <body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <a class="navbar-brand" href="/">Banking System</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item">
            <a class="nav-link" href="/profile">Profile</a>
          </li>
          <li class="nav-item"><a class="nav-link" href="/help">Help</a></li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Transfer Form -->
    <div class="container mt-5">
      <h2 class="text-center">Transfer Funds</h2>
      <form action="/transfer" method="POST">
        <!-- Success Message -->
        <% if (typeof success !== 'undefined') { %>
        <div class="alert alert-success text-center" role="alert">
          <%= success %>
        </div>
        <% } %>
        <!-- Error Message -->
        <% if (typeof error !== 'undefined') { %>
        <div class="alert alert-danger text-center" role="alert">
          <%= error %>
        </div>
        <% } %>
        <div class="form-group mb-3">
          <label for="fromAccount" class="form-label">From Account</label>
          <select
            id="fromAccount"
            name="fromAccount"
            class="form-control"
            required
          >
            <option value="checking">Checking</option>
            <option value="savings">Savings</option>
          </select>
        </div>
        <div class="form-group mb-3">
          <label for="toAccount" class="form-label">To Account</label>
          <select id="toAccount" name="toAccount" class="form-control" required>
            <option value="checking">Checking</option>
            <option value="savings">Savings</option>
          </select>
        </div>
        <div class="form-group mb-3">
          <label for="amount" class="form-label">Amount</label>
          <input
            type="number"
            id="amount"
            name="amount"
            class="form-control"
            required
          />
        </div>
        <div class="form-group mb-3">
          <label for="memo" class="form-label">Memo (Optional)</label>
          <input type="text" id="memo" name="memo" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary w-100">
          <i class="bi bi-arrow-right-circle"></i> Transfer
        </button>
      </form>
      
      <!-- Back to My Accounts Button -->
      <div class="text-center mt-4">
        <a href="<%= backLink %>" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Back to My Accounts
        </a>
      </div>
    </div>
  </body>
</html>
