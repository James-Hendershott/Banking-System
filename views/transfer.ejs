<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Transfer Funds</title>
    <link rel="stylesheet" href="css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
  </head>
  <body>
    <div class="container mt-5">
      <h2 class="text-center text-primary">Transfer Funds</h2>
      <form action="/transfer" method="POST" class="mt-4">
        <div class="mb-3">
          <label for="fromAccount" class="form-label">
            <i class="bi bi-bank"></i> From Account
          </label>
          <select
            id="fromAccount"
            name="fromAccount"
            class="form-select"
            required
          >
            <option value="checking">Checking</option>
            <option value="savings">Savings</option>
          </select>
        </div>
        <div class="mb-3">
          <label for="toAccount" class="form-label">
            <i class="bi bi-arrow-right-square-fill"></i> To Account
          </label>
          <select id="toAccount" name="toAccount" class="form-select" required>
            <option value="checking">Checking</option>
            <option value="savings">Savings</option>
          </select>
        </div>
        <div class="mb-3">
          <label for="amount" class="form-label">
            <i class="bi bi-currency-dollar"></i> Amount
          </label>
          <input
            type="number"
            id="amount"
            name="amount"
            class="form-control"
            required
          />
        </div>
        <div class="mb-3">
          <label for="memo" class="form-label">
            <i class="bi bi-pencil-square"></i> Memo
          </label>
          <input type="text" id="memo" name="memo" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary w-100">
          <i class="bi bi-arrow-right-circle-fill"></i> Transfer
        </button>
      </form>
      <div class="text-center mt-3">
        <a href="/" class="btn btn-primary">
          <i class="bi bi-house-fill"></i> Home
        </a>
      </div>
    </div>
  </body>
</html>
