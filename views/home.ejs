<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Home</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
  </head>
  <body>
    <!-- Include Navbar -->
    <% include partials/navbar %>

    <div class="container mt-5 text-center">
      <h2>Welcome to the Banking System</h2>
      <p>Your secure, online solution for managing your finances.</p>
      <% if (!session.user) { %>
        <a href="/login" class="btn btn-primary m-2">Login</a>
        <a href="/register" class="btn btn-secondary m-2">Register</a>
      <% } else { %>
        <% if (session.user.role === 'customer') { %>
          <a href="/customer/account" class="btn btn-success">Go to My Account</a>
        <% } else if (session.user.role === 'employee') { %>
          <a href="/employee/account" class="btn btn-info">Manage Customers</a>
        <% } else if (session.user.role === 'admin') { %>
          <a href="/admin/account" class="btn btn-warning">Manage Users</a>
        <% } %>
      <% } %>
    </div>
  </body>
</html>