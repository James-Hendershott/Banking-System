<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Customer Account Management</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/bootstrap-icons.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container mt-5">
        <h2 class="text-center">Manage Customer Account</h2>

        <!-- Customer Details -->
        <div class="card mt-4">
            <div class="card-body">
                <h5>Username: <%= customer.username %></h5>
                <h5>Name: <%= customer.first_name %> <%= customer.last_name %></h5>
                <h5>Email: <%= customer.email %></h5>
            </div>
        </div>

        <!-- Account Balances -->
        <h4 class="mt-5">Accounts</h4>
        <div class="card mt-3">
            <div class="card-body">
                <% if (Array.isArray(accounts) && accounts.length > 0) { %>
                  <% accounts.forEach(account => { %>
                    <h5>
                        <a href="/transactions/<%= account.account_id %>" class="text-decoration-none">
                            <%= account.account_type %> Account Balance: $<%= isNaN(account.balance) ? '0.00' : account.balance.toFixed(2) %>
                        </a>
                    </h5>
                <% }); %>
                <% } else { %>
                    <p class="text-danger">No accounts found for this customer.</p>
                <% } %>
            </div>
        </div>

        <!-- Actions -->
        <h4 class="mt-5">Perform Actions</h4>

        <!-- Deposit Form -->
        <h5 class="mt-3">Deposit Funds</h5>
        <form action="/employee/customer/<%= customer.user_id %>/deposit" method="POST">
            <div class="mb-3">
                <label for="depositAccount" class="form-label">Deposit Account</label>
                <select name="account_id" id="depositAccount" class="form-select" required>
                    <option value="" disabled selected>Select an account</option>
                    <% accounts.forEach(account => { %>
                        <option value="<%= account.account_id %>"><%= account.account_type %> ($<%= account.balance %>)</option>
                    <% }); %>
                </select>
            </div>
            <div class="mb-3">
                <label for="depositAmount" class="form-label">Amount</label>
                <input type="number" name="amount" id="depositAmount" class="form-control" min="0.01" step="0.01" required>
            </div>
            <div class="mb-3">
                <label for="depositMemo" class="form-label">Memo</label>
                <input type="text" name="memo" id="depositMemo" class="form-control" placeholder="Optional">
            </div>
            <button type="submit" class="btn btn-success">Deposit</button>
        </form>

        <!-- Withdraw Form -->
        <h5 class="mt-5">Withdraw Funds</h5>
        <form action="/employee/customer/<%= customer.user_id %>/withdraw" method="POST">
            <div class="mb-3">
                <label for="withdrawAccount" class="form-label">Withdraw Account</label>
                <select name="account_id" id="withdrawAccount" class="form-select" required>
                    <option value="" disabled selected>Select an account</option>
                    <% accounts.forEach(account => { %>
                        <option value="<%= account.account_id %>"><%= account.account_type %> ($<%= account.balance %>)</option>
                    <% }); %>
                </select>
            </div>
            <div class="mb-3">
                <label for="withdrawAmount" class="form-label">Amount</label>
                <input type="number" name="amount" id="withdrawAmount" class="form-control" min="0.01" step="0.01" required>
            </div>
            <div class="mb-3">
                <label for="withdrawMemo" class="form-label">Memo</label>
                <input type="text" name="memo" id="withdrawMemo" class="form-control" placeholder="Optional">
            </div>
            <button type="submit" class="btn btn-danger">Withdraw</button>
        </form>

        <!-- Transfer Form -->
        <h5 class="mt-5">Transfer Funds</h5>
        <form action="/employee/customer/<%= customer.user_id %>/transfer" method="POST">
            <div class="mb-3">
                <label for="fromAccount" class="form-label">From Account</label>
                <select name="from_account_id" id="fromAccount" class="form-select" required>
                    <option value="" disabled selected>Select an account</option>
                    <% accounts.forEach(account => { %>
                        <option value="<%= account.account_id %>"><%= account.account_type %> ($<%= account.balance %>)</option>
                    <% }); %>
                </select>
            </div>
            <div class="mb-3">
                <label for="toAccount" class="form-label">To Account</label>
                <select name="to_account_id" id="toAccount" class="form-select" required>
                    <option value="" disabled selected>Select an account</option>
                    <% accounts.forEach(account => { %>
                        <option value="<%= account.account_id %>"><%= account.account_type %> ($<%= account.balance %>)</option>
                    <% }); %>
                </select>
            </div>
            <div class="mb-3">
                <label for="transferAmount" class="form-label">Amount</label>
                <input type="number" name="amount" id="transferAmount" class="form-control" min="0.01" step="0.01" required>
            </div>
            <div class="mb-3">
                <label for="transferMemo" class="form-label">Memo</label>
                <input type="text" name="memo" id="transferMemo" class="form-control" placeholder="Optional">
            </div>
            <button type="submit" class="btn btn-primary">Transfer</button>
        </form>

        <!-- Navigation -->
        <div class="mt-4">
            <a href="/employee/search" class="btn btn-secondary">Back to Search</a>
            <a href="/employee/account" class="btn btn-secondary">Back to Dashboard</a>
        </div>
    </div>
</body>
</html>
