<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Customer Account</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
  </head>
  <body>
    <!-- Include Navbar -->
    <%- include('partials/navbar') %>

    <!-- Customer Account Details -->
    <div class="container mt-5">
      <h2 class="text-center text-primary">Customer Account Details</h2>
      <div class="card mt-4">
        <div class="card-body">
          <h5>Customer ID: <%= customerData.customerId %></h5>
            <h5>
              Checking Account Balance: $<%= accounts.find(acc => acc.type === 'Checking').balance.toFixed(2) %>
              <a href="/employee/customer/<%= accounts.find(acc => acc.type === 'Checking').account_id %>/transactions" class="text-decoration-none ms-3">
                View Transactions
              </a>
            </h5>
            <h5>
              Savings Account Balance: $<%= accounts.find(acc => acc.type === 'Savings').balance.toFixed(2) %>
              <a href="/employee/customer/<%= accounts.find(acc => acc.type === 'Savings').account_id %>/transactions" class="text-decoration-none ms-3">
                View Transactions
              </a>
            </h5>
          <h4 class="mt-5">Transaction History</h4>
          <ul class="list-group">
            <% customerData.recentTransactions.forEach(transaction => { %>
            <li class="list-group-item">
              <%= transaction.date %> - <%= transaction.type %> - $<%= transaction.amount %>
            </li>
            <% }) %>
          </ul>
        </div>
      </div>

      <!-- Deposit Form -->
      <h4 class="mt-5">Deposit Funds</h4>
      <form action="/employee/deposit" method="POST" class="mt-3">
        <div class="mb-3">
          <label for="depositAccount" class="form-label">Account</label>
          <select name="account_id" id="depositAccount" class="form-select">
            <% accounts.forEach(account => { %>
              <option value="<%= account.account_id %>"><%= account.account_type %> ($<%= account.balance %>)</option>
            <% }); %>
          </select>
        </div>
        <div class="mb-3">
          <label for="depositAmount" class="form-label">Amount</label>
          <input type="number" name="amount" id="depositAmount" class="form-control" required />
        </div>
        <div class="mb-3">
          <label for="depositType" class="form-label">Deposit Type</label>
          <select name="deposit_type" id="depositType" class="form-select">
            <option value="cash">Cash</option>
            <option value="check">Check</option>
            <option value="credit_card">Credit Card</option>
          </select>
        </div>
        <div class="mb-3">
          <label for="validationField" class="form-label">Validation (Optional)</label>
          <input type="text" name="validation" id="validationField" class="form-control" />
        </div>
        <button type="submit" class="btn btn-success">Deposit</button>
      </form>

      <!-- Withdraw Form -->
      <h4 class="mt-5">Withdraw Funds</h4>
      <form action="/employee/withdraw" method="POST" class="mt-3">
        <div class="mb-3">
          <label for="withdrawAccount" class="form-label">Account</label>
          <select name="account_id" id="withdrawAccount" class="form-select">
            <% accounts.forEach(account => { %>
              <option value="<%= account.account_id %>"><%= account.account_type %> ($<%= account.balance %>)</option>
            <% }); %>
          </select>
        </div>
        <div class="mb-3">
          <label for="withdrawAmount" class="form-label">Amount</label>
          <input type="number" name="amount" id="withdrawAmount" class="form-control" required />
        </div>
        <button type="submit" class="btn btn-danger">Withdraw</button>
      </form>

      <!-- Back to Employee Account Button -->
      <div class="text-center mt-4">
      <a href="/employee/manage-customer" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Back to Customer Search
      </a>

      </div>
    </div>
  </body>
</html> 