<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Promotion Confirmation</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
    <script>
      // Redirect after 10 seconds
      setTimeout(function () {
        window.location.href = "/admin/account"; // Redirect to admin account page
      }, 10000);
    </script>
  </head>
  <body>
    <div class="container mt-5">
      <h2
        class="text-center <% if (typeof error !== 'undefined') { %>text-danger<% } else { %>text-success<% } %>"
      >
      <% if (typeof error !== 'undefined') { %>
        <h2 class="text-center text-danger">Promotion Failed!</h2>
        <p class="text-center"><strong><%= error %></strong></p>
        <% } else if (typeof success !== 'undefined' && success) { %>
        <h2 class="text-center text-success">User Promotion Successful!</h2>
        <p class="text-center">
            User <strong><%= username %></strong> has been successfully promoted to Admin.
        </p>
        <% } %>
      <div class="text-center mt-4">
        <a href="/admin/account" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Back to My Accounts
        </a>
        <a href="/admin/account-search" class="btn btn-secondary">
          <i class="bi bi-search"></i> Back to User Search
        </a>
      </div>
    </div>
  </body>
</html>
