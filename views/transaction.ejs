<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= accountType %> Account Transactions</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
  </head>
  <body>
    <!-- Navbar -->
    <% include partials/navbar %>
    
    <!-- Account Transactions -->
    <div class="container mt-5">
      <h2 class="text-center text-primary">
        <%= accountType %> Account Transactions
      </h2>
      <ul class="list-group mt-4">
        <% transactionHistory.forEach(transaction => { %>
        <li class="list-group-item">
          <%= transaction.date %> - <%= transaction.type %> - $<%=
          transaction.amount %> - <%= transaction.memo || "N/A" %>
        </li>
        <% }) %>
      </ul>
      <!-- Back to My Accounts Button -->
      <div class="text-center mt-4">
        <a href="/customer/account" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Back to My Accounts
        </a>
      </div>
    </div>
  </body>
</html>
