<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Account</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/bootstrap-icons.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container mt-5">
        <h2 class="text-center text-primary">Admin Dashboard</h2>

        <!-- Search for Customer -->
        <form action="/admin/account-search" method="POST" class="mt-4">
            <div class="input-group mb-3">
                <input type="text" name="username" class="form-control" placeholder="Search by Username" required>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
        </form>

        <!-- Message -->
        <% if (message) { %>
            <div class="alert alert-info text-center">
                <%= message %>
            </div>
        <% } %>

        <!-- User Details -->
        <% if (userAccount) { %>
            <div class="card mt-4">
                <div class="card-body">
                    <h5>Username: <%= userAccount.username %></h5>
                    <h5>Name: <%= userAccount.first_name %> <%= userAccount.last_name %></h5>
                    <h5>Email: <%= userAccount.email %></h5>
                    <h5>Role: <%= userAccount.role %></h5>
                    <h5>Account Types: <%= userAccount.accountTypes.join(', ') %></h5>
                </div>
            </div>

            <!-- Actions -->
            <div class="mt-4">
                <!-- Change Password -->
                <form action="/admin/change-password" method="POST" class="mb-3">
                    <input type="hidden" name="username" value="<%= userAccount.username %>">
                    <div class="input-group">
                        <input type="password" name="newPassword" class="form-control" placeholder="New Password" required>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-key"></i> Reset Password
                        </button>
                    </div>
                </form>

                <!-- Promote to Employee -->
                <form action="/admin/promote-user" method="POST">
                    <input type="hidden" name="username" value="<%= userAccount.username %>">
                    <button type="submit" class="btn btn-success w-100">
                        <i class="bi bi-person-plus"></i> Promote to Employee
                    </button>
                </form>
                <!-- Demote to Customer -->
                <form action="/admin/demote-user" method="POST" class="mt-3">
                    <input type="hidden" name="username" value="<%= userAccount.username %>">
                    <button type="submit" class="btn btn-danger w-100">
                        <i class="bi bi-person-dash"></i> Demote to Customer
                    </button>
                </form>
            </div>
        <% } %>
    </div>
</body>
</html>
