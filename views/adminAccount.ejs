<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Account Management</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/bootstrap-icons.css" />
  </head>
  <body>
    <!-- Include Navbar -->
    <%- include('partials/navbar') %>
    
    <!-- Main Container -->
    <div class="container mt-5">
      <h2 class="text-center text-primary">Admin Account Management</h2>

      <!-- Display Error Message if Exists -->
      <% if (typeof error !== 'undefined') { %>
      <div class="alert alert-danger text-center" role="alert">
        <%= error %>
      </div>
      <% } %>

      <!-- User Search -->
      <div class="mt-5">
        <form action="/admin/account-search" method="POST" class="mt-4">
          <div class="input-group mb-3">
            <input
              type="text"
              name="username"
              class="form-control"
              placeholder="Enter Username"
              required
            />
            <button class="btn btn-primary" type="submit">
              <i class="bi bi-search"></i> Search User
            </button>
          </div>
        </form>
      </div>

      <!-- User Details Section (If userAccount exists) -->
      <% if (userAccount) { %>
        <div class="card mt-4">
          <div class="card-body">
            <h5 class="card-title">User: <%= userAccount.username %></h5>
            <p>First Name: <%= userAccount.first_name %></p>
            <p>Last Name: <%= userAccount.last_name %></p>
            <p>Email: <%= userAccount.email %></p>
            <p>User ID: <%= userAccount.user_id %></p>
  
            <!-- Promote User Form -->
            <form action="/admin/promote-user" method="POST" class="mt-3">
              <input type="hidden" name="username" value="<%= userAccount.username %>" />
              <div class="form-check">
                <input type="checkbox" name="promote" class="form-check-input" id="promoteCheckbox" />
                <label class="form-check-label" for="promoteCheckbox">Promote to Admin</label>
              </div>
              <button type="submit" class="btn btn-success w-100 mt-2">
                <i class="bi bi-person-plus"></i> Promote User
              </button>
            </form>
  
            <!-- Change Password Form -->
            <form action="/admin/change-password" method="POST" class="mt-3">
              <input type="hidden" name="username" value="<%= userAccount.username %>" />
              <div class="mb-3">
                <label for="newPassword" class="form-label">New Password</label>
                <input type="password" name="newPassword" id="newPassword" class="form-control" required />
              </div>
              <button type="submit" class="btn btn-warning w-100">
                <i class="bi bi-key-fill"></i> Change Password
              </button>
            </form>
          </div>
        </div>
        <% } %>
  
        <!-- Navigation Buttons -->
        <div class="text-center mt-4">
          <a href="/admin/account-search" class="btn btn-secondary me-2">
            <i class="bi bi-search"></i> Back to User Search
          </a>
          <a href="/admin/account" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to My Accounts
          </a>
        </div>
      </div>
    </body>
  </html>